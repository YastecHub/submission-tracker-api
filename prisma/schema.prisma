generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  cr
  acr
  fin_sec
  dev
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  name              String
  role              UserRole  @default(cr)
  hasLoggedInBefore Boolean   @default(false)
  pushSubscription  String?
  createdAt         DateTime  @default(now())
  events            SubmissionEvent[]
  paymentEvents     PaymentEvent[]
  transactions      Transaction[]
}

model SubmissionEvent {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  courseCode  String
  type        EventType   @default(assignment)
  description String?
  deadline    DateTime
  isClosed    Boolean     @default(false)
  isDeleted   Boolean     @default(false)
  createdBy   String
  user        User        @relation(fields: [createdBy], references: [id])
  createdAt   DateTime    @default(now())
  submissions Submission[]
}

enum EventType {
  assignment
  attendance
  lab
  other
}

model Submission {
  id           String          @id @default(uuid())
  eventId      String
  event        SubmissionEvent @relation(fields: [eventId], references: [id])
  fullName     String
  matricNumber String
  level        String?
  qrCode       String
  submittedAt  DateTime        @default(now())
  isConfirmed  Boolean         @default(false)
  confirmedAt  DateTime?
  confirmedBy  String?

  @@unique([matricNumber, eventId])
  @@index([eventId, fullName])
  @@index([eventId, matricNumber])
  @@index([eventId, isConfirmed])
}

enum PaymentStatus {
  pending
  confirmed
  rejected
}

enum AmountCheckStatus {
  pending
  matched
  mismatch
  unreadable
  unavailable
}

model PaymentEvent {
  id            String          @id @default(uuid())
  slug          String          @unique
  title         String
  description   String?
  amount        Decimal         @db.Decimal(10, 2)
  accountNumber String
  accountName   String
  bankName      String
  deadline      DateTime
  hasTickets    Boolean         @default(false)
  isClosed      Boolean         @default(false)
  isDeleted     Boolean         @default(false)
  createdBy     String
  creator       User            @relation(fields: [createdBy], references: [id])
  createdAt     DateTime        @default(now())
  receipts      PaymentReceipt[]
}

model PaymentReceipt {
  id              String        @id @default(uuid())
  eventId         String
  event           PaymentEvent  @relation(fields: [eventId], references: [id])
  fullName        String
  matricNumber    String
  level           String?
  extractedAmount Decimal?      @db.Decimal(10, 2)
  amountCheckStatus AmountCheckStatus @default(pending)
  amountCheckConfidence Float?
  amountCheckNote String?
  amountCheckedAt DateTime?
  receiptUrl      String
  receiptPublicId String
  submittedAt     DateTime      @default(now())
  status          PaymentStatus @default(pending)
  confirmedAt     DateTime?
  confirmedBy     String?
  note            String?
  ticketQrCode    String?
  isClaimed       Boolean       @default(false)
  claimedAt       DateTime?
  claimedBy       String?
  transaction     Transaction?

  @@unique([matricNumber, eventId])
  @@index([eventId, fullName])
  @@index([eventId, matricNumber])
  @@index([eventId, status])
  @@index([eventId, isClaimed])
  @@index([eventId, amountCheckStatus])
}

enum TransactionType {
  credit
  debit
}

model Transaction {
  id            String          @id @default(uuid())
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  description   String
  category      String?
  occurredAt    DateTime
  proofUrl      String?
  proofPublicId String?
  recordedBy    String
  recorder      User            @relation(fields: [recordedBy], references: [id])
  receiptId     String?         @unique
  receipt       PaymentReceipt? @relation(fields: [receiptId], references: [id])
  isDeleted     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([occurredAt])
  @@index([isDeleted])
}
