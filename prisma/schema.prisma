generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  cr
  acr
  fin_sec
  dev
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  name              String
  role              UserRole  @default(cr)
  hasLoggedInBefore Boolean   @default(false)
  pushSubscription  String?
  createdAt         DateTime  @default(now())
  events            SubmissionEvent[]
  paymentEvents     PaymentEvent[]
}

model SubmissionEvent {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  courseCode  String
  type        EventType   @default(assignment)
  description String?
  deadline    DateTime
  isClosed    Boolean     @default(false)
  isDeleted   Boolean     @default(false)
  createdBy   String
  user        User        @relation(fields: [createdBy], references: [id])
  createdAt   DateTime    @default(now())
  submissions Submission[]
}

enum EventType {
  assignment
  attendance
  lab
  other
}

model Submission {
  id           String          @id @default(uuid())
  eventId      String
  event        SubmissionEvent @relation(fields: [eventId], references: [id])
  fullName     String
  matricNumber String
  level        String?
  qrCode       String
  submittedAt  DateTime        @default(now())
  isConfirmed  Boolean         @default(false)
  confirmedAt  DateTime?
  confirmedBy  String?

  @@unique([matricNumber, eventId])
}

enum PaymentStatus {
  pending
  confirmed
  rejected
}

model PaymentEvent {
  id            String          @id @default(uuid())
  slug          String          @unique
  title         String
  description   String?
  amount        Decimal         @db.Decimal(10, 2)
  accountNumber String
  accountName   String
  bankName      String
  deadline      DateTime
  isClosed      Boolean         @default(false)
  isDeleted     Boolean         @default(false)
  createdBy     String
  creator       User            @relation(fields: [createdBy], references: [id])
  createdAt     DateTime        @default(now())
  receipts      PaymentReceipt[]
}

model PaymentReceipt {
  id              String        @id @default(uuid())
  eventId         String
  event           PaymentEvent  @relation(fields: [eventId], references: [id])
  fullName        String
  matricNumber    String
  level           String?
  receiptUrl      String
  receiptPublicId String
  submittedAt     DateTime      @default(now())
  status          PaymentStatus @default(pending)
  confirmedAt     DateTime?
  confirmedBy     String?
  note            String?

  @@unique([matricNumber, eventId])
}
